# ─────────────────────────────────────────────────────────────────────────────
# .gitignore – Dharmasthala Events
#
# Rule of thumb: if a file contains secrets, generated output, or is
# machine-specific, it belongs here. Everything else is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── SECRETS (never commit these) ──────────────────────────────────────────────
.env
.env.local
.env.staging
.env.production

# ── TLS / SSL (generated on the server, not stored in git) ───────────────────
*.pem
*.key
*.crt
*.csr
nginx/ssl/
# dhparam.pem is generated by setup-server.sh — takes minutes, not committed
dhparam.pem

# ── PYTHON ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
venv/
.venv/
env/
.env/

# ── DOCKER (keep all compose and Dockerfile, ignore local overrides only) ─────
docker-compose.override.yml

# ── DATABASE BACKUPS (stored on server or cloud, not in git) ─────────────────
backups/
*.archive.gz
*.dump
*.sql

# ── LOGS ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── NODE / FRONTEND BUILD ARTIFACTS (if a build step is ever added) ──────────
node_modules/
.npm/
dist/
.next/
.nuxt/
.cache/

# ── OS / EDITOR ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── MONITORING (runtime data, not config) ─────────────────────────────────────
# Config files (prometheus.yml, alerts.yml, etc.) ARE committed.
# Runtime data is in Docker volumes — not in git.
monitoring/data/
